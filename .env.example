# ============================================
# NirvachakAI — Environment Variables
# Copy this file to .env.local and fill in values
# ============================================

# 1. Google Gemini API
GEMINI_API_KEY=your_gemini_api_key

# 2 & 10. Firebase (Auth + OAuth)
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id

# 3. Cloud Firestore — uses same Firebase project above

# 4. Google Maps
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_maps_api_key

# 5. Cloud Translation API
GOOGLE_TRANSLATE_API_KEY=your_translate_api_key

# 6. Cloud Text-to-Speech
GOOGLE_TTS_API_KEY=your_tts_api_key

# 7. Google Fonts — configured in next/font (no key needed)

# 8. Google reCAPTCHA v3
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=your_recaptcha_site_key
RECAPTCHA_SECRET_KEY=your_recaptcha_secret_key

# 9. YouTube Data API v3
YOUTUBE_API_KEY=your_youtube_api_key
